{
  "project": {
    "name": "rgbgrid-medium",
    "remote_archive_path": "gdrive:wipImages/pbrt-v4"
  },

  "runtime": {
    "pbrt_binary": "/home/rpf4/pbrt-v4/build/pbrt",
    "use_gpu": true,
    "show_stats": true
  },

  "pipeline": {
    "build_scene": { "enabled": true },
    "rclone_sync": { "enabled": true }
  },

  "scene": {
    "master_file":      "scene_files/scene.pbrt",
    "generated_medium": "scene_files/volumes/rgbgrid.pbrt",
    "output_filename":  "rgbgrid_poc.png",

    "camera": {
      "enabled": true,
      "look_at": {
        "eye":  [0, 0, 16.0],
        "look": [0, 2.0, 0],
        "up":   [0, 1, 0]
      },
      "fov": 70
    },

    "sampler": {
      "enabled": true,
      "type": "halton",
      "pixel_samples": 256
    },

    "integrator": {
      "enabled": true,
      "type": "volpath",
      "max_depth": 80
    },

    "film": {
      "enabled": true,
      "x_resolution": 1500,
      "y_resolution": 1000
    },

    "lights": [
      {
        "enabled": false,
        "type": "infinite",
        "color_mode": "blackbody",
        "temperature": 4500,
        "scale": 0.18
      },
      {
        "enabled": false,
        "type": "point",
        "position": [0, 3, -3],
        "color_mode": "blackbody",
        "temperature": 1850,
        "scale": 35.0
      },
      {
        "enabled": false,
        "type": "spot",
        "position": [0, 8, 0],
        "look_at": [0, 0, 0],
        "cone_angle": 20,
        "cone_delta_angle": 5,
        "color_mode": "blackbody",
        "temperature": 5500,
        "scale": 500.0
      },
      {
        "enabled": true,
        "type": "distant",
        "from": [0, 2.0, 10],
        "to": [0, 0, 0],
        "color_mode": "blackbody",
        "temperature": 5500,
        "scale": 4.0
    }
  ],

    "geometry": [
      {
        "enabled": true,
        "label": "ground_plane",
        "material": { "type": "diffuse", "reflectance": [0.35, 0.32, 0.28] },
        "transform": {
          "translate": [0, -1.0, 0],
          "rotate": [{ "angle": 90, "axis": [1, 0, 0] }]
        },
        "shape": {
          "type": "disk",
          "radius": 20.0
        }
      },

      {
        "enabled": false,
        "label": "volume_sphere",
        "material": { "type": "interface" },
        "medium": "rgb_vol",
        "transform": {
          "translate": [0, 0, 0],
          "rotate": [
            { "angle": 150, "axis": [0, 1, 0] },
            { "angle": 20,  "axis": [1, 0, 0] }
          ]
        },
        "shape": {
          "type": "sphere",
          "radius": 1.5
        }
      },

      {
        "enabled": false,
        "label": "volume_box",
        "material": { "type": "interface" },
        "medium": "rgb_vol",
        "transform": { "translate": [0, 0, 0], "rotate": [] },
        "shape": {
          "type": "box",
          "x_min": -18.0, "x_max": 18.0,
          "y_min": -2.0,   "y_max": 16.0,
          "z_min": -9.0,  "z_max": -1.0
        }
      },

      {
        "enabled": false,
        "label": "fog_volume",
        "material": { "type": "interface" },
        "medium_interior": "fog",
        "medium_exterior": "",
        "transform": { "translate": [0, 0, 0] },
        "shape": {
          "type": "sphere",
          "radius": 20.0
        }
      }
    ],

    "grid": {
      "enabled": false,
      "nx": 256,
      "ny": 64,
      "nz": 128,
      "axis": "Y",
      "sigma_a": 0.4,
      "world_min": [-18.0, -2.0, -9.0],
      "world_max": [ 18.0, 16.0, -1.0],
      "emission": {
        "enabled": true,
        "le_scale": 0.010
      },
      "noise": {
        "enabled": true,
        "mode": "position",
        "position": {
          "frequency": 1.5,
          "amplitude": 0.3,
          "octaves": 4,
          "persistence": 0.5,
          "lacunarity": 2.0
        },
        "density": {
          "frequency": 2.0,
          "amplitude": 0.8,
          "octaves": 6,
          "persistence": 0.6,
          "lacunarity": 2.0
        }
      }
    },

    "fog": {
      "enabled": false,
      "sigma_a": 0.0,
      "sigma_s": 0.04,
      "g": 0.0
    },

    "zones": [
      { "enabled": true, "position": 0.2, "wavelength": 650, "width": 0.150, "strength": 12.0 },
      { "enabled": true, "position": 0.4, "wavelength": 580, "width": 0.150, "strength": 12.0 },
      { "enabled": true, "position": 0.6, "wavelength": 510, "width": 0.150, "strength": 12.5 },
      { "enabled": true, "position": 0.8, "wavelength": 450, "width": 0.150, "strength": 12.0 }
    ],

    "foliage": {
      "enabled": true,
      "internode_distance": 0.3,
      "leaf_angle": 45.0,
      "min_loop_index": 15,
      "max_branch_radius": 0.05,
      "leaf_scale": 0.8,
      "leaf_color": [0.15, 0.35, 0.10],
      "leaf": {
        "type": "ovate",
        "length": 1.0,
        "width": 0.5,
        "midrib_curvature": 0.1,
        "blade_curvature": 0.05,
        "min_vein_width": 0.008,
        "venation": {
          "D": 0.05,
          "dk_multiplier": 2.0,
          "di_multiplier": 999.0,
          "num_sources": 200,
          "birth_dist": 0.05,
          "max_loops": 100,
          "max_stuck": 5 
          }
      }
    },  
        
    "tree": {
      "enabled": true,
      "num_leaves": 12000,
      "max_loops": 200,
      "max_stuck": 5,
      "seed": 1,
      "min_leaves": 30,
      "D": 0.2,
      "dk_multiplier": 2.0,
      "di_multiplier": 999.0,
      "birth_dist": 0.15,
      "leaf_width": 1.0,
      "leaf_height": 1.0,
      "leaf_depth": 1.0,
      "point_cloud_center": [0, 5.0, -3.0],
      "point_cloud_radius": 4.0,
      "trunk_radius": 999.0,
      "base_radius": 0.003,
      "joint_radius_multiplier": 1.3,
      "joint_radius_cap": 0.02,
      "root_position": [0, 0.5, -3.0],
      "trunk_material": {
          "type": "diffuse",
          "reflectance": [0.40, 0.35, 0.10]
      },
      "joint_material": {
          "type": "diffuse",
          "reflectance": [0.40, 0.35, 0.10]
      }
    }
  }
}