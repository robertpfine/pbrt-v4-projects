{
  "project": {
    "name": "rgbgrid-medium",
    "remote_archive_path": "gdrive:wipImages/pbrt-v4"
  },

  "runtime": {
    "pbrt_binary": "/home/rpf4/pbrt-v4/build/pbrt",
    "use_gpu": true,
    "show_stats": true
  },

  "pipeline": {
    "build_scene": { "enabled": true },
    "rclone_sync": { "enabled": true }
  },

  "scene": {
    "master_file":      "scene_files/scene.pbrt",
    "generated_medium": "scene_files/volumes/rgbgrid.pbrt",
    "output_filename":  "rgbgrid_poc.png",

    "camera": {
      "enabled": true,
      "look_at": {
        "eye":  [3, 1, -10],
        "look": [0, -0.25, 0],
        "up":   [0, 1, 0]
      },
      "fov": 45
    },

    "sampler": {
      "enabled": true,
      "type": "halton",
      "pixel_samples": 128
    },

    "integrator": {
      "enabled": true,
      "type": "volpath",
      "max_depth": 20
    },

    "film": {
      "enabled": true,
      "x_resolution": 500,
      "y_resolution": 500
    },

    "lights": [
      {
        "enabled": false,
        "type": "infinite",
        "color_mode": "blackbody",
        "temperature": 4500,
        "scale": 0.18
      },
      {
        "enabled": false,
        "type": "point",
        "position": [0, 3, -3],
        "color_mode": "blackbody",
        "temperature": 1850,
        "scale": 35.0
      },

      {
        "enabled": true,
        "type": "spot",
        "position": [0, 8, 0],
        "look_at": [0, 0, 0],
        "cone_angle": 20,
        "cone_delta_angle": 5,
        "color_mode": "blackbody",
        "temperature": 5500,
        "scale": 500.0
}
    ],

    "geometry": [
      {
        "enabled": true,
        "label": "ground_plane",
        "material": { "type": "diffuse", "reflectance": [0.35, 0.32, 0.28] },
        "transform": {
        "translate": [0, -1.55, 0],
        "rotate": [{ "angle": 90, "axis": [1, 0, 0] }]
        },
        "shape": {
        "type": "disk",
        "radius": 5.0
        }
      },

      {
        "enabled": true,
        "label": "volume_sphere",
        "material": { "type": "interface" },
        "medium": "rgb_vol",
        "transform": {
          "translate": [0, 0, 0],
          "rotate": [
            { "angle": 150, "axis": [0, 1, 0] },
            { "angle": 20,  "axis": [1, 0, 0] }]},
        "shape": {
          "type": "sphere",
          "radius": 1.5
        }
      },

      {
        "enabled": false,
        "label": "fog_volume",
        "material": { "type": "interface" },
        "medium_interior": "fog",
        "medium_exterior": "",
        "transform": { "translate": [0, 0, 0] },
        "shape": {
            "type": "sphere",
            "radius": 20.0
        }
      }
    ],

    "grid": {
      "nx": 128,
      "ny": 128,
      "nz": 128,
      "axis": "X",
      "sigma_a": 0.4,
      "world_min": -2.0,
      "world_max": 2.0
    },

    


    "fog": {
      "enabled": false,
      "sigma_a": 0.0,
      "sigma_s": 0.04,
      "g": 0.0
    },


    "fog": {
      "enabled": true,
      "sigma_a": 0.0,
      "sigma_s": 0.04,
      "g": 0.0
    },
    
    "zones": [
      { "enabled": true, "position": 0.2, "wavelength": 650, "width": 0.050, "strength": 12.0 },
      { "enabled": true, "position": 0.4, "wavelength": 580, "width": 0.050, "strength": 12.0 },
      { "enabled": true, "position": 0.6, "wavelength": 510, "width": 0.050, "strength": 12.5 },
      { "enabled": true, "position": 0.8, "wavelength": 450, "width": 0.050, "strength": 12.0 }
    ]
  }
}