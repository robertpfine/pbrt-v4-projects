LookAt 0 0 -12   0 6 3   0 1 0
Camera "perspective" "float fov" [50]

Film "image"
    "string filename" "godrays_v3_test4.png"
    "integer xresolution" [800]
    "integer yresolution" [600]

Sampler "halton" "integer pixelsamples" [256]
Integrator "volpath" "integer maxdepth" [64]

MakeNamedMedium "fog" "string type" "homogeneous"
    "rgb sigma_a" [0.0 0.0 0.0]
    "rgb sigma_s" [0.06 0.06 0.06]
    "float g" [0.7]

MediumInterface "" "fog"

WorldBegin

MediumInterface "fog" "fog"

# Bright light high up and behind the occluders
# Spotlight from above/behind
LightSource "spot"
    "point from" [0 20 5]
    "point to" [0 0 0]
    "float coneangle" [20]
    "float conedeltaangle" [5]
    "rgb I" [800 800 800]

# Occluder 1 - blocks part of light
AttributeBegin
    Translate -1.5 6 2
    Material "matte" "rgb Kd" [0.1 0.1 0.1]
    Shape "sphere" "float radius" [1.2]
AttributeEnd

# Occluder 2
AttributeBegin
    Translate 1.5 7 3
    Material "matte" "rgb Kd" [0.1 0.1 0.1]
    Shape "sphere" "float radius" [1.0]
AttributeEnd

# Occluder 3
AttributeBegin
    Translate 0 5 1
    Material "matte" "rgb Kd" [0.1 0.1 0.1]
    Shape "sphere" "float radius" [0.8]
AttributeEnd

# Fog boundary
AttributeBegin
    MediumInterface "fog" ""
    Material "none"
    Shape "sphere" "float radius" [50]
AttributeEnd

# Ground
AttributeBegin
    Material "matte" "rgb Kd" [0.15 0.15 0.15]
    Shape "trianglemesh"
        "integer indices" [0 1 2  0 2 3]
        "point P" [-30 0 -30   30 0 -30   30 0 30   -30 0 30]
AttributeEnd

WorldEnd