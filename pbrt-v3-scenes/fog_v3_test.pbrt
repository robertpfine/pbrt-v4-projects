# PBRT-v3 Simple Fog Test

LookAt 0 2 -8   0 3 2   0 1 0
Camera "perspective" "float fov" [50]

Film "image"
    "string filename" "fog_v3_test.png"
    "integer xresolution" [800]
    "integer yresolution" [600]

Sampler "halton" "integer pixelsamples" [128]
Integrator "volpath" "integer maxdepth" [64]

MakeNamedMedium "fog" "string type" "homogeneous"
    "rgb sigma_a" [0.0 0.0 0.0]
    "rgb sigma_s" [0.2 0.2 0.2]
    "float g" [0.0]

MediumInterface "" "fog"

WorldBegin

MediumInterface "fog" "fog"

AttributeBegin
    Translate 0 12 3
    AreaLightSource "diffuse" "rgb L" [50 50 50] "float scale" [2000]
    Material "matte" "rgb Kd" [0 0 0]
    Shape "sphere" "float radius" [1.0]
AttributeEnd

AttributeBegin
    Translate 0 5 3
    Material "matte" "rgb Kd" [0.1 0.1 0.8]
    Shape "sphere" "float radius" [1.0]
AttributeEnd

AttributeBegin
    MediumInterface "fog" ""
    Material "none"
    Shape "sphere" "float radius" [50]
AttributeEnd

AttributeBegin
    Material "matte" "rgb Kd" [0.1 0.1 0.1]
    Shape "trianglemesh"
        "integer indices" [0 1 2  0 2 3]
        "point P" [-30 0 -30   30 0 -30   30 0 30   -30 0 30]
AttributeEnd

WorldEnd